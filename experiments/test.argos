      <links ref="b">
        <link id="b" geometry="box" mass="0.3" size="0.250,0.250,0.200"/>
      </links>
    </prototype>

    <!-- Start and goal markers -->

    <prototype id="start_marker" movable="false">
      <body position="-7.000,-7.000,0.250"/>
      <links ref="b">
        <link id="b" geometry="sphere" mass="0.1" radius="0.180"/>
      </links>
    </prototype>

    <prototype id="goal_marker" movable="false">
      <body position="7.000,7.000,0.250"/>
      <links ref="b">
        <link id="b" geometry="sphere" mass="0.1" radius="0.180"/>
      </links>
    </prototype>

    <!-- Influential agents: 4 / 30 = 13.33 percent of swarm -->

    <prototype id="infl_0" movable="true">
      <body position="-7.000,-7.000,1.500"/>
      <controller config="infl"/>
      <links ref="b">
        <link id="b" geometry="sphere" mass="0.15" radius="0.065"/>

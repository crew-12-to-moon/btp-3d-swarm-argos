<?xml version="1.0" ?>
<argos-configuration>

  <framework>
    <system threads="0"/>
    <experiment length="2000000" ticks_per_second="10" random_seed="1"/>
  </framework>

  <physics_engines>
    <dynamics3d id="dyn3d"/>
  </physics_engines>

  <media></media>

  <controllers>
    <infl id="infl" library="/Users/harshvardhanmohite/btp_3d_fresh/build/libbtp_controller.dylib">
      <actuators/>
      <sensors/>
      <params/>
    </infl>

    <dec id="dec" library="/Users/harshvardhanmohite/btp_3d_fresh/build/libbtp_controller.dylib">
      <actuators/>
      <sensors/>
      <params/>
    </dec>
  </controllers>

  <loop_functions library="/Users/harshvardhanmohite/btp_3d_fresh/build/libbtp_loop.dylib" label="loop"/>

  <arena size="10,10,3" center="0,0,1.5">

    <!-- No floor: avoids ARGoS floor/source XML issue -->

    <!-- ========================================================= -->
    <!-- STATIC BUILDING-LIKE OBSTACLES                            -->
    <!-- Must match obstacle logic inside btp_loop_functions.cpp     -->
    <!-- ========================================================= -->

    <prototype id="bld_0" movable="false">
      <body position="-1.7,-0.6,0.8"/>
      <links ref="b">
        <link id="b" geometry="box" mass="5.0" size="0.9,1.6,1.6"/>
      </links>
    </prototype>

    <prototype id="bld_1" movable="false">
      <body position="1.4,-0.3,0.9"/>
      <links ref="b">
        <link id="b" geometry="box" mass="5.0" size="1.0,1.3,1.8"/>
      </links>
    </prototype>

    <prototype id="bld_2" movable="false">
      <body position="-0.8,1.6,0.9"/>
      <links ref="b">
        <link id="b" geometry="box" mass="5.0" size="1.4,0.9,1.8"/>
      </links>
    </prototype>

    <prototype id="bld_3" movable="false">
      <body position="2.2,1.8,0.8"/>
      <links ref="b">
        <link id="b" geometry="box" mass="5.0" size="0.9,1.1,1.6"/>
      </links>
    </prototype>

    <!-- ========================================================= -->
    <!-- INFLUENTIAL CORE                                          -->
    <!-- ========================================================= -->

    <prototype id="infl_0" movable="true">
      <body position="-3.00,-3.00,1.0"/>
      <controller config="infl"/>
      <links ref="b">
        <link id="b" geometry="sphere" mass="0.1" radius="0.05"/>
      </links>
    </prototype>

    <prototype id="infl_1" movable="true">
      <body position="-2.82,-3.00,1.0"/>
      <controller config="infl"/>
      <links ref="b">
        <link id="b" geometry="sphere" mass="0.1" radius="0.05"/>
      </links>
    </prototype>

    <prototype id="infl_2" movable="true">

<?xml version="1.0" ?>
<argos-configuration>

  <framework>
    <system threads="0"/>
    <experiment length="3000000" ticks_per_second="10" random_seed="1"/>
  </framework>

  <physics_engines>
    <dynamics3d id="dyn3d"/>
  </physics_engines>

  <media></media>

  <controllers>
    <infl id="infl" library="/Users/harshvardhanmohite/btp_3d_fresh/build/libbtp_controller.dylib">
      <actuators/>
      <sensors/>
      <params/>
    </infl>

    <dec id="dec" library="/Users/harshvardhanmohite/btp_3d_fresh/build/libbtp_controller.dylib">
      <actuators/>
      <sensors/>
      <params/>
    </dec>
  </controllers>

  <loop_functions library="/Users/harshvardhanmohite/btp_3d_fresh/build/libbtp_loop.dylib" label="loop"/>

  <arena size="18,18,5" center="0,0,2.5">

    <!-- Reduced building obstacle environment: 6 buildings + 3 small aerial obstacles -->
    <!-- No floor: avoids ARGoS floor/source XML issues -->

    <prototype id="bld_0" movable="false">
      <body position="-4.800,-4.000,1.100"/>
      <links ref="b">
        <link id="b" geometry="box" mass="10.0" size="1.200,1.400,2.200"/>
      </links>
    </prototype>

    <prototype id="bld_1" movable="false">
      <body position="-1.300,-4.500,1.200"/>
      <links ref="b">
        <link id="b" geometry="box" mass="10.0" size="1.300,1.100,2.400"/>
      </links>
    </prototype>

    <prototype id="bld_2" movable="false">
      <body position="-5.200,0.000,1.300"/>
      <links ref="b">
        <link id="b" geometry="box" mass="10.0" size="1.200,1.500,2.600"/>
      </links>
    </prototype>

    <prototype id="bld_3" movable="false">
      <body position="-1.500,1.200,1.400"/>
      <links ref="b">
        <link id="b" geometry="box" mass="10.0" size="1.500,1.100,2.800"/>
      </links>
    </prototype>

    <prototype id="bld_4" movable="false">

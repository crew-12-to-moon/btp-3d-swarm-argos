      <links ref="b">
        <link id="b" geometry="box" mass="10.0" size="1.400,1.200,2.600"/>
      </links>
    </prototype>

    <prototype id="bld_5" movable="false">
      <body position="4.800,4.200,1.200"/>
      <links ref="b">
        <link id="b" geometry="box" mass="10.0" size="1.300,1.400,2.400"/>
      </links>
    </prototype>

    <!-- Small moving aerial obstacles; motion controlled by loop_functions.cpp -->

    <prototype id="air_0" movable="true">
      <body position="-3.500,-1.500,2.250"/>
      <links ref="b">
        <link id="b" geometry="box" mass="0.3" size="0.280,0.280,0.220"/>
      </links>
    </prototype>

    <prototype id="air_1" movable="true">
      <body position="0.800,2.800,2.350"/>
      <links ref="b">
        <link id="b" geometry="box" mass="0.3" size="0.260,0.260,0.220"/>
      </links>
    </prototype>

    <prototype id="air_2" movable="true">
